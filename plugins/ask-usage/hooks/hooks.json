  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT\"/scripts/fetch-usage.mjs",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
